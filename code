    lcd.print("Sensor OK");
  } else {
    Serial.println("Sensor NOT found");
    lcd.setCursor(0, 0);
    lcd.print("Sensor Failed");
    while (1);
  }
  delay(2000); lcd.clear();


  EEPROM.begin(4096);
