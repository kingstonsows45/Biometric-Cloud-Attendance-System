// Save user info (name, path)
void saveUserInfo(int id, const String& name, const String& path) {
  int base = EEPROM_USER_START + (id * USER_INFO_SIZE);
  EEPROM.write(base, 0);  // Initial count = 0
  for (int i = 0; i < NAME_SIZE; i++)
    EEPROM.write(base + 1 + i, i < name.length() ? name[i] : 0);
  for (int i = 0; i < PATH_SIZE; i++)
    EEPROM.write(base + 1 + NAME_SIZE + i, i < path.length() ? path[i] : 0);
  EEPROM.commit();
}

// Load user info
void loadUserInfo(int id, String &name, String &path, uint8_t &count) {
  int base = EEPROM_USER_START + (id * USER_INFO_SIZE);
  count = EEPROM.read(base);
  name = "";
  path = "";
  for (int i = 0; i < NAME_SIZE; i++) {
    char c = EEPROM.read(base + 1 + i);
    if (c == 0) break;
    name += c;
  }
  for (int i = 0; i < PATH_SIZE; i++) {
    char c = EEPROM.read(base + 1 + NAME_SIZE + i);
    if (c == 0) break;
    path += c;
  }
}

void updateUserCount(int id, uint8_t count) {
  int base = EEPROM_USER_START + (id * USER_INFO_SIZE);
  EEPROM.write(base, count);
  EEPROM.commit();
}

void listAllUsers() {
  Serial.println("Listing all enrolled users:");
  for (int id = 1; id <= MAX_ID; id++) {
    String uname, path;
    uint8_t count;
    loadUserInfo(id, uname, path, count);
    if (uname.length() > 0 && path.length() > 0) {
      Serial.print("ID: "); Serial.print(id);
      Serial.print(" | Name: "); Serial.print(uname);
      Serial.print(" | Path: "); Serial.print(path);
      Serial.print(" | Count: "); Serial.println(count);
    }
  }
}

void postToFirebase(const char* method, String& path, const String& data) {
  String url = path + ".json?auth=" + FIREBASE_AUTH;
  Serial.println("Sending data to Firebase...");
  Serial.println("URL: " + url);
  Serial.println("Data: " + data);

  httpClient.beginRequest();
  httpClient.patch(url, "application/json", data);
  httpClient.endRequest();

  int statusCode = httpClient.responseStatusCode();
  String response = httpClient.responseBody();

  Serial.print("Status: "); Serial.println(statusCode);
  Serial.print("Response: "); Serial.println(response);

  if (!httpClient.connected()) httpClient.stop();
}

uint8_t getFingerprintEnroll() {
  int p = -1;

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Place finger");
  Serial.println("Place finger...");

  // Wait for good image
  while ((p = finger.getImage()) != FINGERPRINT_OK);

  p = finger.image2Tz(1);
  if (p != FINGERPRINT_OK) {
    lcd.clear();
    lcd.print("1st Img Fail");
    Serial.println("Failed to convert image 1");
    delay(2000);
    return false;
  }

  lcd.clear();
  lcd.print("Remove finger");
  Serial.println("Remove finger...");
  delay(2000);
  while (finger.getImage() != FINGERPRINT_NOFINGER);

  lcd.clear();
  lcd.print("Place same");
  lcd.setCursor(0, 1);
  lcd.print("finger again");
  Serial.println("Place same finger again...");
  while ((p = finger.getImage()) != FINGERPRINT_OK);

  p = finger.image2Tz(2);
  if (p != FINGERPRINT_OK) {
    lcd.clear();
    lcd.print("2nd Img Fail");
    Serial.println("Failed to convert image 2");
    delay(2000);
    return false;
  }

  p = finger.createModel();
  if (p != FINGERPRINT_OK) {
    lcd.clear();
    lcd.print("Model Fail");
    Serial.println("Could not create model");
    delay(2000);
    return false;
  }

  p = finger.storeModel(currentID);
  if (p == FINGERPRINT_OK) {
    lcd.clear();
    lcd.print("Enroll Success");
    Serial.println("Fingerprint enrolled!");
    delay(2000);
    return true;
  } else {
    lcd.clear();
    lcd.print("Store Fail");
    Serial.println("Could not store fingerprint");
    delay(2000);
    return false;
  }
}


int getFingerprintID() {
  if (finger.getImage() != FINGERPRINT_OK) lcd.print("image failed");return -1;
  if (finger.image2Tz() != FINGERPRINT_OK)lcd.print("img2Tz failed") return -1;
  if (finger.fingerSearch() != FINGERPRINT_OK)lcd.print("search failed") return -1;
  return finger.fingerID;
}

