  Serial.print("Start ID: "); Serial.println(currentID);
  lcd.setCursor(0, 0); lcd.print("Ready ID: ");
  lcd.print(currentID);
  delay(2000); lcd.clear();
  Serial.println("Type ENROLL, DELETE <id>, DELETEALL, LIST");
}

void loop() {
  if (Serial.available()) {
