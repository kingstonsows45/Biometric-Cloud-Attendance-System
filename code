        EEPROM.write(EEPROM_ID_ADDR, currentID);
        EEPROM.commit();
      } else {
        Serial.println("Enroll failed");
      }
    }

   else if (cmd.equalsIgnoreCase("DELETEALL")) {
  finger.emptyDatabase();
  Serial.println("All fingerprints deleted");

  for (int id = 1; id <= MAX_ID; id++) {
    int base = EEPROM_USER_START + (id * USER_INFO_SIZE);
    for (int i = 0; i < USER_INFO_SIZE; i++) {
      EEPROM.write(base + i, 0);
    }
  }
  EEPROM.write(EEPROM_ID_ADDR, 1); // Reset currentID to 1
  EEPROM.commit();
  Serial.println("All EEPROM user data cleared");
}

  else if (cmd.startsWith("DELETE ")) {
  int id = cmd.substring(7).toInt();
  if (finger.deleteModel(id) == FINGERPRINT_OK) {
